rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: cek role user yang sedang login ─────────────────────────────
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isSuperAdmin() {
      return request.auth != null && userRole() == 'superadmin';
    }
    function isAdmin() {
      return request.auth != null && (userRole() == 'admin' || userRole() == 'superadmin');
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    // Semua user login bisa baca; hanya diri sendiri atau superadmin yang bisa update
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ─── Activities ──────────────────────────────────────────────────────────
    // Semua user login bisa baca & buat; update/delete oleh pemilik atau admin dinas
    match /activities/{activityId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == resource.data.userId || isAdmin();
      allow delete: if request.auth.uid == resource.data.userId || isAdmin();
    }

    // ─── Dinas ───────────────────────────────────────────────────────────────
    // Siapapun bisa baca (termasuk sebelum login, untuk form registrasi)
    // Hanya superadmin yang bisa tambah/edit/hapus
    match /dinas/{dinasId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ─── Settings ────────────────────────────────────────────────────────────
    // Semua user login bisa baca; admin & superadmin bisa tulis
    match /settings/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
